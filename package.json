{
  "name": "taviraq",
  "productName": "Taviraq",
  "version": "0.0.0",
  "description": "AI-native macOS terminal with built-in assistant workflows and safe command execution.",
  "author": "Soshnikov Artem",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "package:mac": "npm run package:mac:unsigned",
    "package:mac:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false COPYFILE_DISABLE=1 electron-builder --mac dir --publish never",
    "package:mac:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false COPYFILE_DISABLE=1 electron-builder --mac --publish never",
    "package:mac:signed": "npm run build && COPYFILE_DISABLE=1 electron-builder --mac --publish never -c.mac.identity=\"$CSC_NAME\"",
    "rebuild:native:arm64": "electron-rebuild -f -w keytar -w node-pty -a arm64",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests electron.vite.config.ts vitest.config.ts",
    "changelog": "node scripts/generate-changelog.mjs --changelog /tmp/taviraq-changelog.md && cat /tmp/taviraq-changelog.md",
    "record:demo": "node scripts/record-demo.mjs",
    "record:demo:gif": "node scripts/record-demo.mjs --gif"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.dokant.taviraq",
    "productName": "Taviraq",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/keytar/**/*",
      "node_modules/node-pty/**/*"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "npmRebuild": false,
    "nativeRebuilder": null,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "pkg",
        "zip"
      ]
    },
    "pkg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22 <23"
  }
}
